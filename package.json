{
  "name": "10d-sniper-frontend-build",
  "version": "1.0.0",
  "description": "Build tools for 10D Sniper Frontend",
  "scripts": {
    "build:css": "npx tailwindcss -i ./frontend/input.css -o ./frontend/dist/styles.css --minify",
    "build:js": "npx babel ./frontend/app.jsx -o ./frontend/dist/app.js --presets @babel/preset-react",
    "build": "npm run build:css && npm run build:js"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19"
  }
}
